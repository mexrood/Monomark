{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Monomark",
  "version": "1.0.43",
  "identifier": "app.marrow.monomark",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Monomark",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/sidecar.js"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mexrood/Monomark/releases/latest/download/latest.json"
      ],
      "pubkey": "RWTOCX3zzo3WrBv52b3brwP6s3pim51yct76eCuvQF8cUgWfzbJASKkm"
    }
  }
}
