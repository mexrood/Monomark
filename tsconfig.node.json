{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": "dist-electron",
    "rootDir": "electron",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["electron"]
}
