{
  "name": "monomark",
  "version": "1.0.9",
  "description": "A focused markdown knowledge-base for thinking alongside Claude Code",
  "author": {
    "name": "Monomark",
    "email": "hello@marrow.app"
  },
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n VITE,ELECTRON -c cyan,yellow \"vite\" \"electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder --win",
    "build:x64": "tsc -p tsconfig.node.json && vite build && electron-builder --win --x64",
    "build:dir": "tsc -p tsconfig.node.json && vite build && electron-builder --dir",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.mjs"
  },
  "keywords": [
    "markdown",
    "notes",
    "knowledge-base",
    "claude",
    "electron"
  ],
  "devDependencies": {
    "@types/auto-launch": "^5.0.5",
    "@types/express": "^5.0.6",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tiptap/extension-code-block-lowlight": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-task-item": "^3.22.5",
    "@tiptap/extension-task-list": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.22.5",
    "auto-launch": "^5.0.6",
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-mark": "^4.0.0",
    "minisearch": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.12"
  }
}
